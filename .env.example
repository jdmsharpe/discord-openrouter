# Environment variables example file - copy to .env and fill in your values
BOT_TOKEN=your_value_here
GUILD_IDS=your_value_here
OPENROUTER_API_KEY=your_value_here

# Optional: default chat model if a conversation or channel default is not set
# OPENROUTER_DEFAULT_TEXT_MODEL=minimax/minimax-m2.7

# Optional: default image model for /openrouter image
# OPENROUTER_DEFAULT_IMAGE_MODEL=google/gemini-3.1-flash-image-preview

# Optional: default text-to-speech model for /openrouter tts
# OPENROUTER_DEFAULT_TTS_MODEL=openai/gpt-audio

# Optional: default speech-to-text model for /openrouter stt
# OPENROUTER_DEFAULT_STT_MODEL=openai/gpt-audio

# Optional: default PDF parsing engine for PDF attachments in /openrouter chat
# Supported values: cloudflare-ai, mistral-ocr, native
# Deprecated alias pdf-text is normalized to cloudflare-ai
# OPENROUTER_DEFAULT_PDF_ENGINE=cloudflare-ai

# Optional: app attribution headers for OpenRouter rankings/analytics
# OPENROUTER_SITE_URL=https://your-site.example
# OPENROUTER_APP_NAME=discord-openrouter
# OPENROUTER_APP_CATEGORIES=productivity,discord bots

# Optional: cache model metadata from OpenRouter for this many seconds (default: 300)
# OPENROUTER_MODEL_CACHE_TTL_SECONDS=300

# Optional: show cost and token usage embeds in Discord (default: true; accepts true/1/yes)
# SHOW_COST_EMBEDS=true
